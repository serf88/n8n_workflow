# ═══════════════════════════════════════════════════════════
# Hotel Cruise Como — Agentico AI Automation Stack
# Copia questo file in .env e compila con i valori reali
# MAI committare il file .env su GitHub!
# ═══════════════════════════════════════════════════════════

# ─────────────────────────────────────────────
# n8n Configuration
# ─────────────────────────────────────────────
N8N_USER=admin
N8N_PASSWORD=changeme_strong_password_here
N8N_HOST=localhost
N8N_WEBHOOK_BASE_URL=https://your-n8n-domain.com
N8N_ENCRYPTION_KEY=generate_32char_random_string_here

# ─────────────────────────────────────────────
# PostgreSQL Database
# ─────────────────────────────────────────────
POSTGRES_DB=hotel_cruise_db
POSTGRES_USER=hotel_cruise_user
POSTGRES_PASSWORD=changeme_db_password_here

# ─────────────────────────────────────────────
# pgAdmin (solo debug)
# ─────────────────────────────────────────────
PGADMIN_EMAIL=admin@hotelcruisecomo.it
PGADMIN_PASSWORD=changeme_pgadmin_password

# ─────────────────────────────────────────────
# Hotel Email
# ─────────────────────────────────────────────
HOTEL_EMAIL_FROM=info@hotelcruisecomo.it
HOTEL_EMAIL_FROM_NAME=Hotel Cruise Como

# ─────────────────────────────────────────────
# SendGrid (Email Transazionale)
# ─────────────────────────────────────────────
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here

# ─────────────────────────────────────────────
# OpenAI (AI Agent)
# ─────────────────────────────────────────────
OPENAI_API_KEY=sk-your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# ─────────────────────────────────────────────
# Telegram Bot (Staff Notifications)
# ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_STAFF_CHAT_ID=-100your_group_chat_id

# ─────────────────────────────────────────────
# Twilio WhatsApp Business
# ─────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACyour_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=+14155238886
# Numero WhatsApp hotel (da attivare su Twilio):
HOTEL_WHATSAPP_NUMBER=+39031XXXXXXX

# ─────────────────────────────────────────────
# Booking.com Channel Manager (o mock per demo)
# ─────────────────────────────────────────────
BOOKING_COM_PROPERTY_ID=your_property_id
BOOKING_COM_API_KEY=your_booking_api_key
# Demo mode: usa "mock" per simulare webhook senza API reale
BOOKING_MODE=mock

# ─────────────────────────────────────────────
# Airbnb (se applicabile)
# ─────────────────────────────────────────────
AIRBNB_CLIENT_ID=your_airbnb_client_id
AIRBNB_CLIENT_SECRET=your_airbnb_client_secret

# ─────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─────────────────────────────────────────────
# Demo/Testing
# ─────────────────────────────────────────────
DEMO_MODE=true
DEMO_EMAIL_OVERRIDE=test@agentico.it
# Se DEMO_MODE=true, tutte le email vengono reindirizzate a DEMO_EMAIL_OVERRIDE

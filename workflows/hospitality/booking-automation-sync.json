{
  "name": "Hotel Cruise Como — Booking Automation Sync",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "hotel-cruise-booking",
        "responseMode": "lastNode",
        "options": {}
      },
      "id": "webhook-booking",
      "name": "Webhook — New Booking",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [240, 400],
      "notes": "Riceve prenotazioni da Booking.com, Airbnb, Expedia, sito proprietario. Payload normalizzato: { source, booking_id, guest_name, guest_email, guest_phone, checkin_date, checkout_date, room_type, special_requests, dietary_restrictions, total_amount }"
    },
    {
      "parameters": {
        "values": {
          "string": [
            {
              "name": "normalized_source",
              "value": "={{$json[\"source\"] || 'direct'}}"
            },
            {
              "name": "booking_ref",
              "value": "={{$json[\"booking_id\"] || 'HCC-' + $now.toFormat('yyyyMMdd') + '-' + Math.random().toString(36).substr(2,6).toUpperCase()}}"
            },
            {
              "name": "nights",
              "value": "={{Math.ceil((new Date($json[\"checkout_date\"]) - new Date($json[\"checkin_date\"])) / (1000*60*60*24))}}"
            },
            {
              "name": "guest_email_lower",
              "value": "={{$json[\"guest_email\"].toLowerCase().trim()}}"
            }
          ]
        }
      },
      "id": "normalize-booking",
      "name": "Normalize Booking Data",
      "type": "n8n-nodes-base.set",
      "typeVersion": 1,
      "position": [460, 400],
      "notes": "Normalizza i dati provenienti da canali diversi (Booking.com, Airbnb, Expedia) in formato unico. Calcola notti e genera ref interna."
    },
    {
      "parameters": {
        "operation": "select",
        "schema": "public",
        "table": "guests",
        "where": {
          "values": [
            {
              "column": "email",
              "value": "={{$json[\"guest_email_lower\"]}}"
            }
          ]
        },
        "options": {}
      },
      "id": "check-existing-guest",
      "name": "PostgreSQL — Check Existing Guest",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 1,
      "position": [680, 400],
      "credentials": {
        "postgres": {
          "id": "postgres-hotel-cruise",
          "name": "PostgreSQL Hotel Cruise"
        }
      },
      "notes": "Verifica se l'ospite esiste già nel CRM. Se sì → UPDATE. Se no → INSERT nuovo profilo."
    },
    {
      "parameters": {
        "conditions": {
          "number": [
            {
              "value1": "={{$json[\"id\"] !== undefined ? 1 : 0}}",
              "operation": "equal",
              "value2": 1
            }
          ]
        }
      },

    {
      "parameters": {
        "fromEmail": "={{$env.HOTEL_EMAIL_FROM}}",
        "toEmail": "={{$node['Webhook — New Booking'].json.guest_email}}",
        "subject": "Benvenuto/a a Hotel Cruise Como — Prenotazione Confermata #{{$node['Normalize Booking Data'].json.booking_ref}}",
        "emailType": "html",
        "message": "<!DOCTYPE html><html><body style='font-family:Arial,sans-serif;color:#333;max-width:600px;margin:0 auto'>\n<div style='background:#1a3a5c;padding:30px;text-align:center'>\n  <h1 style='color:white;margin:0'>Hotel Cruise Como</h1>\n  <p style='color:#a8c5e8;margin:5px 0'>Lago di Como — Eleganza sul lago</p>\n</div>\n<div style='padding:30px'>\n  <h2>Ciao {{$node['Webhook — New Booking'].json.guest_name.split(' ')[0]}}! 👋</h2>\n  <p>La tua prenotazione è <strong>confermata</strong>. Non vediamo l'ora di accoglierti!</p>\n  <div style='background:#f0f4f8;border-radius:8px;padding:20px;margin:20px 0'>\n    <h3 style='margin-top:0;color:#1a3a5c'>📋 Dettagli Prenotazione</h3>\n    <p><strong>Riferimento:</strong> {{$node['Normalize Booking Data'].json.booking_ref}}</p>\n    <p><strong>Check-in:</strong> {{$node['Webhook — New Booking'].json.checkin_date}} dalle 14:00</p>\n    <p><strong>Check-out:</strong> {{$node['Webhook — New Booking'].json.checkout_date}} entro le 11:00</p>\n    <p><strong>Camera:</strong> {{$node['Webhook — New Booking'].json.room_type}} — Stanza {{$node['PostgreSQL — Room Assignment'].json.room_number}}</p>\n    <p><strong>Notti:</strong> {{$node['Normalize Booking Data'].json.nights}}</p>\n  </div>\n  <div style='background:#e8f4e8;border-radius:8px;padding:20px;margin:20px 0'>\n    <h3 style='margin-top:0;color:#2d6a2d'>📱 Check-in Digitale</h3>\n    <p>Compila il <a href='https://checkin.hotelcruisecomo.it?ref={{$node[\"Normalize Booking Data\"].json.booking_ref}}' style='color:#1a3a5c'>modulo pre check-in online</a> per evitare attese alla reception!</p>\n  </div>\n  <div style='background:#fff3e0;border-radius:8px;padding:20px;margin:20px 0'>\n    <h3 style='margin-top:0;color:#e65100'>🌊 Attività sul Lago</h3>\n    <p>Vuoi prenotare un tour del Lago di Como, una cena romantica o un transfer dall'aeroporto? Rispondici direttamente a questa email o scrivici su WhatsApp!</p>\n  </div>\n  <p>A presto,<br><strong>Il Team di Hotel Cruise Como</strong></p>\n  <p style='color:#666;font-size:12px'>📍 Via Regina 28, Como | 📞 +39 031 XXX XXX | 🌐 hotelcruisecomo.it</p>\n</div>\n</body></html>",
        "options": {}
      },
      "id": "welcome-email",
